{
  "name": "cube-baby-presets-live",
  "version": "0.7.0",
  "description": "Live editor for Cuvave Cube Baby effects presets",
  "main": "dist/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:windows": "tsc -p tsconfig.main.json && vite build && electron-builder --win --x64 --publish never",
    "build:android": "vite build && npx cap copy android && cd android && .\\gradlew assembleDebug",
    "start": "electron ."
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "esbuild": "^0.28.1",
    "i18next": "^26.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "shell-quote": "^1.8.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.6.0",
    "vite": "^8.0.16",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.cubebaby.presets",
    "productName": "Cube Baby Presets",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
